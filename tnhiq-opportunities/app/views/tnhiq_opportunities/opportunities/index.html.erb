<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="csrf-token" content="<%= form_authenticity_token %>">
  <title>Opportunity Board — TNHIQ</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; }
    body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", system-ui, sans-serif; max-width: 960px; margin: 1.5rem auto; padding: 1rem; line-height: 1.5; color: #222; }
    h1 { font-size: 1.5rem; margin-bottom: .25rem; }
    .lead { color: #666; margin-bottom: 1rem; }
    .filters { display: flex; flex-wrap: wrap; gap: .5rem; margin-bottom: 1rem; padding: .75rem; background: #f5f5f5; border-radius: 6px; }
    .filters select, .filters input { padding: .4rem .6rem; border: 1px solid #ccc; border-radius: 4px; font-size: .9rem; }
    .filters button { padding: .4rem 1rem; background: #25aae2; color: white; border: 0; border-radius: 4px; cursor: pointer; }
    .opp { padding: .75rem 1rem; border: 1px solid #ddd; border-radius: 6px; margin: .5rem 0; }
    .opp:hover { background: #fafafa; }
    .opp .title { font-weight: 600; font-size: 1.05rem; }
    .opp .meta { color: #666; font-size: .85rem; margin-top: .25rem; }
    .badge { display: inline-block; padding: .1rem .5rem; border-radius: 3px; font-size: .75rem; font-weight: 600; margin-right: .25rem; }
    .badge.tier-free      { background: #e0f3ff; color: #0066aa; }
    .badge.tier-core      { background: #fff3e0; color: #aa5500; }
    .badge.tier-premium   { background: #f0e6ff; color: #5500aa; }
    .badge.tier-founder   { background: #ffe0e6; color: #aa0033; }
    .badge.verified       { background: #e0ffe0; color: #007700; }
    .empty { padding: 2rem; text-align: center; color: #888; }
    .pagination { display: flex; justify-content: space-between; margin-top: 1rem; color: #666; }
    a { color: #25aae2; text-decoration: none; }
    a:hover { text-decoration: underline; }
  </style>
</head>
<body>
  <h1>Opportunities</h1>
  <p class="lead">
    <%= @total_count %> active opportunit<%= @total_count == 1 ? "y" : "ies" %>
    visible to your <span class="badge tier-<%= @user_tier %>"><%= @user_tier.titleize %></span> tier.
  </p>

  <form class="filters" method="get" action="/opportunities">
    <select name="equipment_type">
      <option value="">Any equipment</option>
      <% ::TnhiqOpportunities::Opportunity::EQUIPMENT_TYPES.each do |eq| %>
        <option value="<%= eq %>" <%= "selected" if @filters["equipment_type"] == eq %>><%= eq.titleize %></option>
      <% end %>
    </select>
    <input type="text" name="origin_state" placeholder="Origin (e.g. CA)" maxlength="2" value="<%= @filters['origin_state'] %>" style="width:6rem">
    <input type="text" name="destination_state" placeholder="Dest (e.g. TX)" maxlength="2" value="<%= @filters['destination_state'] %>" style="width:6rem">
    <input type="text" name="commodity" placeholder="Commodity" value="<%= @filters['commodity'] %>">
    <select name="source_type">
      <option value="">Any source</option>
      <% ::TnhiqOpportunities::Opportunity::SOURCE_TYPES.each do |st| %>
        <option value="<%= st %>" <%= "selected" if @filters['source_type'] == st %>><%= st.titleize %></option>
      <% end %>
    </select>
    <select name="sort">
      <option value="">Newest</option>
      <option value="expiring_soon" <%= "selected" if @filters['sort'] == 'expiring_soon' %>>Expiring soon</option>
      <option value="most_interest" <%= "selected" if @filters['sort'] == 'most_interest' %>>Most interest</option>
    </select>
    <button type="submit">Filter</button>
  </form>

  <% if @opportunities.empty? %>
    <div class="empty">No opportunities match your filters yet. Try widening the search.</div>
  <% else %>
    <% @opportunities.each do |opp| %>
      <div class="opp">
        <div class="title">
          <a href="/opportunities/<%= opp.id %>"><%= opp.title %></a>
        </div>
        <div class="meta">
          <span class="badge tier-<%= opp.tier_required %>"><%= opp.tier_required.titleize %></span>
          <% if opp.requires_verified %><span class="badge verified">Verified only</span><% end %>
          <% if opp.equipment_type.present? %><strong><%= opp.equipment_type.titleize %></strong> · <% end %>
          <% if opp.origin_state.present? || opp.destination_state.present? %>
            <%= opp.origin_state.presence || "?" %> → <%= opp.destination_state.presence || "?" %> ·
          <% end %>
          <% if opp.commodity.present? %><%= opp.commodity %> · <% end %>
          <%= opp.source_label.presence || opp.source_type.titleize %>
          <% if opp.expires_at.present? %> · expires <%= opp.expires_at.strftime("%b %d") %><% end %>
        </div>
      </div>
    <% end %>
  <% end %>

  <div class="pagination">
    <% if @page > 1 %>
      <a href="?<%= URI.encode_www_form(@filters.merge('page' => @page - 1)) %>">← Previous</a>
    <% else %><span></span><% end %>
    <span>Page <%= @page %></span>
    <% if @opportunities.size == @page_size %>
      <a href="?<%= URI.encode_www_form(@filters.merge('page' => @page + 1)) %>">Next →</a>
    <% else %><span></span><% end %>
  </div>
</body>
</html>
