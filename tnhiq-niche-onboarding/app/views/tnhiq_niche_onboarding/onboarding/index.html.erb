<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="csrf-token" content="<%= form_authenticity_token %>">
  <title>Welcome — TNHIQ Community</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; }
    body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", system-ui, sans-serif; max-width: 640px; margin: 2rem auto; padding: 1rem; line-height: 1.5; color: #222; }
    h1 { font-size: 1.5rem; margin-bottom: .25rem; }
    .lead { color: #666; margin-bottom: 1.5rem; }
    .progress { display: flex; gap: .25rem; margin-bottom: 1rem; }
    .progress span { flex: 1; height: 4px; background: #e5e5e5; border-radius: 2px; }
    .progress span.done { background: #25aae2; }
    fieldset { border: 0; padding: 0; margin: 0; }
    legend { font-size: 1.1rem; font-weight: 600; margin-bottom: .75rem; }
    label.option { display: block; padding: .75rem 1rem; border: 1px solid #ddd; border-radius: 6px; margin: .375rem 0; cursor: pointer; transition: background .1s; }
    label.option:hover { background: #f5f5f5; }
    label.option input { margin-right: .5rem; }
    .step { display: none; }
    .step.active { display: block; }
    .actions { display: flex; justify-content: space-between; margin-top: 1.5rem; }
    button { padding: .75rem 1.5rem; background: #25aae2; color: white; border: 0; border-radius: 6px; cursor: pointer; font-size: 1rem; font-weight: 500; }
    button.secondary { background: transparent; color: #666; border: 1px solid #ddd; }
    button:disabled { opacity: .5; cursor: not-allowed; }
    .error { color: #c0392b; margin-top: .5rem; }
  </style>
</head>
<body>
  <h1>Welcome to TNHIQ Community</h1>
  <p class="lead">Three quick questions so we route you to the right places.</p>

  <div class="progress" aria-hidden="true">
    <span class="done"></span><span></span><span></span>
  </div>

  <form id="onboarding-form" novalidate>
    <fieldset class="step active" data-step="1">
      <legend>What kind of operator are you?</legend>
      <% [
        ["owner_operator",  "Owner-Operator"],
        ["fleet_owner",     "Fleet Owner"],
        ["freight_broker",  "Freight Broker"],
        ["dispatcher",      "Dispatcher"],
        ["last_mile_dsp",   "Last Mile / DSP"],
        ["box_truck",       "Box Truck / Expedited"],
        ["hotshot",         "Hotshot"],
        ["warehousing_3pl", "Warehousing / 3PL"],
        ["getting_started", "Getting Started (not yet operating)"],
      ].each do |key, label| %>
        <label class="option"><input type="radio" name="niche" value="<%= key %>" required> <%= label %></label>
      <% end %>
      <div class="actions">
        <span></span>
        <button type="button" data-next>Next</button>
      </div>
    </fieldset>

    <fieldset class="step" data-step="2">
      <legend>What equipment do you run? (select all that apply)</legend>
      <% [
        ["dry_van",         "Dry Van"],
        ["reefer",          "Reefer"],
        ["flatbed",         "Flatbed"],
        ["step_deck",       "Step Deck"],
        ["rgn",             "RGN"],
        ["box_truck",       "Box Truck"],
        ["cargo_van",       "Cargo Van"],
        ["sprinter",        "Sprinter"],
        ["hotshot_trailer", "Hotshot / Trailer"],
        ["other",           "Other"],
      ].each do |key, label| %>
        <label class="option"><input type="checkbox" name="equipment[]" value="<%= key %>"> <%= label %></label>
      <% end %>
      <div class="actions">
        <button type="button" class="secondary" data-prev>Back</button>
        <button type="button" data-next>Next</button>
      </div>
    </fieldset>

    <fieldset class="step" data-step="3">
      <legend>Where are you in your business?</legend>
      <% [
        ["pre_launch",  "Pre-launch"],
        ["year_one",    "Year 1"],
        ["growing",     "Growing (2–5 trucks)"],
        ["scaling",     "Scaling (5+ trucks)"],
        ["established", "Established"],
      ].each do |key, label| %>
        <label class="option"><input type="radio" name="stage" value="<%= key %>" required> <%= label %></label>
      <% end %>
      <div class="actions">
        <button type="button" class="secondary" data-prev>Back</button>
        <button type="submit" id="finish">Finish</button>
      </div>
      <p class="error" id="error" hidden></p>
    </fieldset>
  </form>

  <script>
    (function() {
      const form  = document.getElementById("onboarding-form");
      const error = document.getElementById("error");
      const finish = document.getElementById("finish");
      const progress = document.querySelectorAll(".progress span");
      let current = 1;

      function show(step) {
        document.querySelectorAll(".step").forEach(s => s.classList.remove("active"));
        document.querySelector('[data-step="' + step + '"]').classList.add("active");
        progress.forEach((p, i) => p.classList.toggle("done", i < step));
        current = step;
      }

      function stepValid(stepEl) {
        const required = stepEl.querySelector('input[type="radio"][required]');
        if (!required) return true;
        return [...stepEl.querySelectorAll('input[type="radio"]')].some(r => r.checked);
      }

      form.addEventListener("click", (e) => {
        if (e.target.matches("[data-next]")) {
          const stepEl = e.target.closest(".step");
          if (!stepValid(stepEl)) {
            error.textContent = "Please make a selection to continue.";
            error.hidden = false;
            return;
          }
          error.hidden = true;
          show(current + 1);
        } else if (e.target.matches("[data-prev]")) {
          error.hidden = true;
          show(current - 1);
        }
      });

      form.addEventListener("submit", async (e) => {
        e.preventDefault();
        const data = new FormData(form);
        const stage = data.get("stage");
        if (!stage) {
          error.textContent = "Please choose a business stage.";
          error.hidden = false;
          return;
        }

        finish.disabled = true;
        finish.textContent = "Saving…";
        error.hidden = true;

        try {
          const csrf = document.querySelector('meta[name="csrf-token"]').content;
          const res = await fetch("/onboarding/submit", {
            method:      "POST",
            credentials: "same-origin",
            headers: {
              "Content-Type": "application/json",
              "X-CSRF-Token": csrf,
            },
            body: JSON.stringify({
              niche:     data.get("niche"),
              equipment: data.getAll("equipment[]"),
              stage:     stage,
            }),
          });

          const json = await res.json().catch(() => ({}));
          if (res.ok && json.ok) {
            window.location.href = "/";
          } else {
            error.textContent = "Save failed: " + ((json.errors || ["unknown"]).join(", "));
            error.hidden = false;
            finish.disabled = false;
            finish.textContent = "Finish";
          }
        } catch (err) {
          error.textContent = "Network error — please try again.";
          error.hidden = false;
          finish.disabled = false;
          finish.textContent = "Finish";
        }
      });
    })();
  </script>
</body>
</html>
